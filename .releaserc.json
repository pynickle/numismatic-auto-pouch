{
  "branches": [
    "master"
  ],
  "plugins": [
    "@semantic-release/commit-analyzer",
    [
      "@semantic-release/release-notes-generator",
      {
        "preset": "conventionalcommits",
        "presetConfig": {
          "types": [
            { "type": "feat", "section": "✨ Features" },
            { "type": "fix", "section": "🐛 Bug Fixes" },
            { "type": "docs", "section": "📚 Documentation" },
            { "type": "style", "section": "💄 Style Improvements" },
            { "type": "ref", "section": "♻️ Code Refactoring" },
            { "type": "perf", "section": "⚡ Performance Improvements" },
            { "type": "test", "section": "✅ Tests" },
            { "type": "build", "section": "📦 Build System" },
            { "type": "ci", "section": "👷 CI/CD" },
            { "type": "chore", "section": "🔧 Miscellaneous Changes" },
            { "type": "imp", "section": "🚀 Improvements" }
          ]
        },
        "parserOpts": {
          "noteKeywords": ["BREAKING CHANGE", "BREAKING CHANGES"]
        }
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "./gradlew :fabric:build -Pmod_version=${nextRelease.version} && ./gradlew :neoforge:build -Pmod_version=${nextRelease.version}"
      }
    ],
    "@semantic-release/changelog",
    [
      "@semantic-release/git",
      {
        "assets": [
          "CHANGELOG.md"
        ],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
    [
      "semantic-release-minecraft",
      {
        "game_versions": ["1.20.1"],
        "mod_loaders": "fabric",
        "display_name": "[Fabric 1.20.1] ${ nextRelease.version }",
        "glob": "build/libs/Numismatic-Auto-Pouch-${ nextRelease.version }.jar",
        "curseforge": {
          "project_id": "1482836",
          "java_versions": 21,
          "environments": ["client", "server"]
        },
        "modrinth": {
          "project_id": "2JCwfLJX",
          "version_number": "${ nextRelease.version }+fabric"
        }
      }
    ]
  ],
  "preset": "conventionalcommits",
  "releaseRules": [
    {
      "type": "ref",
      "release": "patch"
    },
    {
      "type": "style",
      "release": "patch"
    },
    {
      "type": "imp",
      "release": "patch"
    }
  ]
}